# PayMongo Environment Configuration
# Copy this file to .env and update with your actual keys

# PayMongo API Keys
PAYMONGO_PUBLIC_KEY=pk_test_YOUR_PUBLIC_KEY_HERE
PAYMONGO_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE

# For production, use:
# PAYMONGO_PUBLIC_KEY=pk_live_YOUR_PUBLIC_KEY_HERE
# PAYMONGO_SECRET_KEY=sk_live_YOUR_SECRET_KEY_HERE

# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App Configuration
APP_NAME=Yang Chow Restaurant
APP_SCHEME=yangchow
DOMAIN=your-domain.site
